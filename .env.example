# ============================================================
#   Cortex AI — Environment Variables
#   انسخ هذا الملف باسم .env واملأ القيم
# ============================================================

# ---------- Discord Application ----------
DISCORD_CLIENT_ID=1518400019105972306
DISCORD_CLIENT_SECRET=__PUT_YOUR_CLIENT_SECRET_HERE__
DISCORD_BOT_TOKEN=__PUT_YOUR_BOT_TOKEN_HERE__

# رابط الـ OAuth Callback (لازم يطابق المسجل بـ Discord Developer Portal بالضبط)
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# ---------- Database (Neon PostgreSQL) ----------
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-bitter-leaf-ah3m2umt.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require

# ---------- AI Provider ----------
MISTRAL_API_KEY=__PUT_YOUR_MISTRAL_KEY_HERE__

# ---------- Dashboard / Sessions ----------
# مفتاح سري طويل وعشوائي لتوقيع الـ JWT / الجلسات — ولّده بنفسك، لا تستخدم قيمة افتراضية
SESSION_SECRET=__GENERATE_A_LONG_RANDOM_STRING__
PORT=3000
NODE_ENV=development

# دومين الموقع الحقيقي وقت الإنتاج (يُستخدم لبناء روابط الدعوة وروابط OAuth)
PUBLIC_URL=http://localhost:3000
